# x402 / payment
PAYMENT_ADDRESS=0x...          # USDC recipient wallet on Base
NETWORK=base-sepolia           # base | base-sepolia

# Server
PORT=3000
HOST=0.0.0.0

# SecretVM
ATTESTATION_ENDPOINT=http://172.17.0.1:29343/cpu
SECRETVM_AGENT_PRIVATE_KEY=    # EVM wallet private key for SecretVM agent API
SECRETVM_VM_ID=                # This VM's ID from SecretVM dashboard

# Optional: comma-separated list of allowed LLM provider hostnames
# Leave empty to allow all HTTPS endpoints in the default list
ALLOWED_PROVIDERS=

# Set to 'true' to disable payment gating for local testing ONLY
# Never set this in production
DISABLE_PAYMENT=
